{
  "name": "microdocx",
  "version": "1.0.0",
  "description": "A collection of 20 free casual games with AI opponents, leaderboards, and achievements",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "capacitor:init": "capacitor init",
    "capacitor:add": "capacitor add",
    "capacitor:sync": "capacitor sync",
    "capacitor:open:ios": "capacitor open ios",
    "capacitor:open:android": "capacitor open android"
  },
  "keywords": [
    "games",
    "ludo",
    "chess",
    "sudoku",
    "board-games",
    "casual-games",
    "pwa",
    "offline",
    "ai-opponent",
    "leaderboard"
  ],
  "author": "Microdocx",
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/2026microdocx-netizen/microdocx.git"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "stockfish.js": "^10.0.2",
    "chess.js": "^1.0.0-beta.8",
    "matter-js": "^0.19.0",
    "phaser": "^3.60.0",
    "@capacitor/core": "^5.5.0",
    "@capacitor/android": "^5.5.0",
    "@capacitor/ios": "^5.5.0",
    "@capacitor/app": "^5.0.0",
    "@capacitor/share": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0"
  }
}
