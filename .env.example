# Microdocx Environment Variables
# ===================================
# Copy this to .env.local and fill in your actual API keys
# NEVER commit .env.local to Git — it's protected by .gitignore

# ===== MONETIZATION =====

# Google AdSense (Web)
VITE_GOOGLE_ADSENSE_ID=ca-pub-your-adsense-id-here

# Google AdMob (Mobile)
VITE_ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
VITE_ADMOB_BANNER_ID=ca-app-pub-3940256099942544/6300978111
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
VITE_ADMOB_REWARDED_ID=ca-app-pub-3940256099942544/5224354917

# Razorpay (India Payments)
VITE_RAZORPAY_KEY_ID=rzp_live_your_live_key_here
VITE_RAZORPAY_KEY_SECRET=your_key_secret_here

# ===== ANALYTICS =====

# Google Analytics 4
VITE_GA4_ID=G-your-ga4-measurement-id

# ===== PREMIUM & COSMETICS =====

# Gumroad (optional: selling cosmetics)
# VITE_GUMROAD_URL=https://gumroad.com/your-profile

# ===== STORAGE & BACKEND (For Future Use) =====

# Supabase (if you add global leaderboards later)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Firebase (if you migrate from localStorage later)
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
# VITE_FIREBASE_DATABASE_URL=https://your-app.firebaseio.com
# VITE_FIREBASE_STORAGE_BUCKET=your-app.appspot.com

# ===== MULTIPLAYER (For Future Use) =====

# Socket.io server (if you add online multiplayer)
# VITE_SOCKET_SERVER_URL=https://your-multiplayer-server.com
# VITE_SOCKET_SERVER_PORT=443

# ===== BUILD & DEPLOYMENT =====

# Environment
NODE_ENV=development

# GitHub Pages base URL (if games aren't at root domain)
VITE_BASE_URL=/

# ===== FEATURE FLAGS =====

# Enable/disable features without rebuilding
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ADS=true
VITE_ENABLE_PREMIUM=false
VITE_ENABLE_COSMETICS=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ACHIEVEMENTS=true
VITE_ENABLE_DARK_MODE=true

# ===== GAME CONFIGURATION =====

# Max players per game
VITE_MAX_PLAYERS=4

# Default language
VITE_DEFAULT_LANGUAGE=en

# ===== DEBUGGING =====

# Enable console logs in production
VITE_DEBUG_MODE=false

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE=true
